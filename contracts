#[program]
pub mod pexmon_staking {
    use super::*;

    /// Initialize the staking pool
    pub fn initialize_pool(ctx: Context<InitializePool>, config: PoolConfig) -> Result<()> {
        let pool = &mut ctx.accounts.pool;
        pool.authority = ctx.accounts.authority.key();
        pool.total_staked = 0;
        pool.config = config;
        pool.is_active = true;

        msg!("PEXMON Staking Pool initialized");
        Ok(())
    }

    /// Stake $PEXMON tokens to a specific beast faction
    pub fn stake(ctx: Context<Stake>, amount: u64, faction: Faction) -> Result<()> {
        require!(amount >= ctx.accounts.pool.config.min_stake, StakingError::BelowMinimum);

        // Transfer tokens to pool
        let cpi_accounts = Transfer {
            from: ctx.accounts.user_token.to_account_info(),
            to: ctx.accounts.pool_vault.to_account_info(),
            authority: ctx.accounts.user.to_account_info(),
        };
        let cpi_program = ctx.accounts.token_program.to_account_info();
        token::transfer(CpiContext::new(cpi_program, cpi_accounts), amount)?;

        // Update stake record
        let stake_record = &mut ctx.accounts.stake_record;
        stake_record.owner = ctx.accounts.user.key();
        stake_record.faction = faction.clone();
        stake_record.amount += amount;
        stake_record.last_staked = Clock::get()?.unix_timestamp;

        // Update pool
        let pool = &mut ctx.accounts.pool;
        pool.total_staked += amount;

        emit!(Staked {
            user: ctx.accounts.user.key(),
            faction,
            amount,
            timestamp: Clock::get()?.unix_timestamp,
        });

        Ok(())
    }

    /// Unstake $PEXMON tokens
    pub fn unstake(ctx: Context<Unstake>, amount: u64) -> Result<()> {
        let stake_record = &mut ctx.accounts.stake_record;
        require!(stake_record.amount >= amount, StakingError::InsufficientStake);

        stake_record.amount -= amount;

        let pool = &mut ctx.accounts.pool;
        pool.total_staked -= amount;

        emit!(Unstaked {
            user: ctx.accounts.user.key(),
            amount,
            timestamp: Clock::get()?.unix_timestamp,
        });

        Ok(())
    }

    /// Claim rewards for winning faction
    pub fn claim_rewards(ctx: Context<ClaimRewards>) -> Result<()> {
        let stake_record = &ctx.accounts.stake_record;
        require!(stake_record.amount > 0, StakingError::NoStake);

        emit!(RewardsClaimed {
            user: ctx.accounts.user.key(),
            timestamp: Clock::get()?.unix_timestamp,
        });

        Ok(())
    }
}

