    /// Initialize the arena with four agent vaults
    pub fn initialize_arena(ctx: Context<InitializeArena>, config: ArenaConfig) -> Result<()> {
        let arena = &mut ctx.accounts.arena;
        arena.authority = ctx.accounts.authority.key();
        arena.season = 1;
        arena.status = ArenaStatus::Active;
        arena.prize_pool = 0;
        arena.config = config;
        arena.created_at = Clock::get()?.unix_timestamp;

        msg!("PEXMON Arena initialized — Season {}", arena.season);
        Ok(())
    }

    /// Register an AI agent to the arena
    pub fn register_agent(
        ctx: Context<RegisterAgent>,
        agent_type: AgentType,
        name: String,
    ) -> Result<()> {
        let agent = &mut ctx.accounts.agent;
        agent.agent_type = agent_type;
        agent.name = name;
        agent.wallet = ctx.accounts.agent_wallet.key();
        agent.total_trades = 0;
        agent.win_count = 0;
        agent.total_pnl = 0;
        agent.followers = 0;
        agent.is_active = true;

        msg!("Agent {} registered to arena", agent.name);
        Ok(())
    }

    /// Record a completed trade by an agent
    pub fn record_trade(
        ctx: Context<RecordTrade>,
        pnl: i64,
        trade_type: TradeType,
    ) -> Result<()> {
        let agent = &mut ctx.accounts.agent;
        agent.total_trades += 1;
        agent.total_pnl += pnl;

        if pnl > 0 {
            agent.win_count += 1;
        }

        emit!(TradeRecorded {
            agent: agent.key(),
            pnl,
            trade_type,
            timestamp: Clock::get()?.unix_timestamp,
        });

        Ok(())
    }

    /// Stake tokens to join a faction
    pub fn stake_to_faction(ctx: Context<StakeToFaction>, amount: u64) -> Result<()> {
        let staker = &mut ctx.accounts.staker_account;
        staker.owner = ctx.accounts.owner.key();
        staker.agent = ctx.accounts.agent.key();
        staker.amount += amount;
        staker.staked_at = Clock::get()?.unix_timestamp;

        let agent = &mut ctx.accounts.agent;
        agent.followers += 1;

        msg!("Staked {} $PEXMON to faction {}", amount, agent.name);
        Ok(())
    }

    /// Settle the season and distribute rewards
    pub fn settle_season(ctx: Context<SettleSeason>) -> Result<()> {
        let arena = &mut ctx.accounts.arena;
        require!(arena.status == ArenaStatus::Active, ArenaError::NotActive);

        // Determine winner by highest PnL
        // Distribution logic handled off-chain with verification
        arena.season += 1;
        arena.prize_pool = 0;

        emit!(SeasonSettled {
            season: arena.season - 1,
            timestamp: Clock::get()?.unix_timestamp,
        });

        msg!("Season {} settled. Starting Season {}", arena.season - 1, arena.season);
        Ok(())
    }

    /// Execute buyback and burn from agent profits
    pub fn buyback_and_burn(ctx: Context<BuybackBurn>, amount: u64) -> Result<()> {
        require!(amount > 0, ArenaError::InvalidAmount);

        emit!(BuybackExecuted {
            amount,
            timestamp: Clock::get()?.unix_timestamp,
        });

        msg!("Buyback & burn executed: {} $PEXMON", amount);
        Ok(())
    }
}

