#[program]
pub mod pexmon_buyback {
    use super::*;

    /// Initialize the buyback engine
    pub fn initialize(ctx: Context<Initialize>, config: BuybackConfig) -> Result<()> {
        let engine = &mut ctx.accounts.engine;
        engine.authority = ctx.accounts.authority.key();
        engine.total_burned = 0;
        engine.total_buybacks = 0;
        engine.config = config;

        msg!("PEXMON Buyback Engine initialized");
        Ok(())
    }

    /// Execute a buyback using agent profits
    pub fn execute_buyback(ctx: Context<ExecuteBuyback>, sol_amount: u64) -> Result<()> {
        require!(sol_amount > 0, BuybackError::ZeroAmount);

        let engine = &mut ctx.accounts.engine;
        engine.total_buybacks += 1;

        emit!(BuybackTriggered {
            sol_amount,
            buyback_number: engine.total_buybacks,
            timestamp: Clock::get()?.unix_timestamp,
        });

        msg!("Buyback #{} executed with {} lamports", engine.total_buybacks, sol_amount);
        Ok(())
    }

    /// Burn purchased tokens permanently
    pub fn burn_tokens(ctx: Context<BurnTokens>, amount: u64) -> Result<()> {
        require!(amount > 0, BuybackError::ZeroAmount);

        let engine = &mut ctx.accounts.engine;
        engine.total_burned += amount;

        emit!(TokensBurned {
            amount,
            total_burned: engine.total_burned,
            timestamp: Clock::get()?.unix_timestamp,
        });

        msg!("Burned {} $PEXMON — Total burned: {}", amount, engine.total_burned);
        Ok(())
    }
}

